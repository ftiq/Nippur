            <field name="task_type">visit</field>
            <field name="partner_id" ref="demo_doctor6"/>
            <field name="associated_partner_id" ref="demo_doctor6"/>
            <field name="user_id" ref="demo_user_rep3"/>
            <field name="scheduled_date">2026-03-05 10:00:00</field>
            <field name="priority">1</field>
            <field name="description">زيارة تعريفية أولى ضمن خطة عدن الأسبوعية.</field>
            <field name="state">pending</field>
            <field name="plan_id" ref="demo_plan_rep3_week10"/>
            <field name="plan_line_id" ref="demo_plan3_line_doctor6"/>
            <field name="project_id" ref="demo_project_plan_rep3_week10"/>
            <field name="project_task_id" ref="demo_project_task_plan3_line_doctor6"/>
            <field name="tag_ids" eval="[(6, 0, [ref('demo_task_followup')])]"/>
        </record>
        <record id="demo_plan3_line_doctor6" model="ftiq.weekly.plan.line">
            <field name="daily_task_id" ref="demo_task_visit_pending_doctor6"/>
            <field name="project_task_id" ref="demo_project_task_plan3_line_doctor6"/>
        </record>

        <!-- تحسين عرض الطلبات والفواتير والتحصيل -->
        <record id="demo_field_order_rep1_doctor1" model="sale.order">
            <field name="ftiq_delivery_notes">التسليم صباحاً عبر سيارة التوزيع مع التأكيد على حساسية التخزين.</field>
            <field name="note">طلبية ميدانية ناتجة عن زيارة معتمدة للطبيب.</field>
        </record>
        <record id="demo_field_order_rep2_doctor5" model="sale.order">
            <field name="ftiq_delivery_notes">التسليم إلى العيادة خلال 24 ساعة مع متابعة التحصيل الجزئي.</field>
            <field name="note">طلبية ميدانية لعيادة السكري بعد زيارة متابعة.</field>
