            <field name="name">زيارة الدكتور سالم باعباد - خطة عمر</field>
            <field name="project_id" ref="demo_project_plan_rep3_week10"/>
            <field name="partner_id" ref="demo_doctor6"/>
            <field name="user_ids" eval="[(6, 0, [ref('demo_user_rep3')])]"/>
            <field name="date_deadline">2026-03-05 23:59:59</field>
            <field name="planned_date_begin">2026-03-05 10:00:00</field>
            <field name="ftiq_plan_id" ref="demo_plan_rep3_week10"/>
            <field name="ftiq_plan_line_id" ref="demo_plan3_line_doctor6"/>
