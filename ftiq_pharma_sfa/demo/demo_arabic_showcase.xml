            <field name="ftiq_license_attached" eval="True"/>
            <field name="ftiq_general_note">عميل تجريبي أضيف لسيناريو معالج الخطة بفلاتر العراق وبغداد والاسكان والجلدية.</field>
        </record>

        <!-- فرق المبيعات وربطها بالمشرفين والمندوبين -->
        <record id="demo_team_sanaa" model="crm.team">
            <field name="name">فريق صنعاء الطبي</field>
            <field name="user_id" ref="demo_user_supervisor1"/>
            <field name="company_id" ref="base.main_company"/>
        </record>
        <record id="demo_team_aden" model="crm.team">
            <field name="name">فريق عدن الطبي</field>
            <field name="user_id" ref="demo_user_supervisor2"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="demo_team_member_rep1" model="crm.team.member">
            <field name="crm_team_id" ref="demo_team_sanaa"/>
            <field name="user_id" ref="demo_user_rep1"/>
        </record>
        <record id="demo_team_member_rep2" model="crm.team.member">
            <field name="crm_team_id" ref="demo_team_sanaa"/>
            <field name="user_id" ref="demo_user_rep2"/>
        </record>
        <record id="demo_team_member_rep3" model="crm.team.member">
            <field name="crm_team_id" ref="demo_team_aden"/>
            <field name="user_id" ref="demo_user_rep3"/>
        </record>

        <!-- تعريب أسماء الحسابات واليوميات المستخدمة في الديمو -->
        <record id="demo_account_receivable_ftiq" model="account.account">
            <field name="name">ذمم مدينة تجريبية - FTIQ</field>
        </record>
        <record id="demo_account_income_ftiq" model="account.account">
            <field name="name">إيراد تجريبي - FTIQ</field>
        </record>
        <record id="demo_account_cash_ftiq" model="account.account">
            <field name="name">صندوق نقدي تجريبي - FTIQ</field>
        </record>
        <record id="demo_journal_sale_ftiq" model="account.journal">
            <field name="name">يومية مبيعات ميدانية تجريبية</field>
        </record>
        <record id="demo_journal_cash_ftiq" model="account.journal">
            <field name="name">يومية تحصيل نقدي تجريبية</field>
        </record>
        <record id="demo_payment_method_line_cash_in_ftiq" model="account.payment.method.line">
            <field name="name">تحصيل نقدي ميداني</field>
        </record>
        <record id="demo_payment_method_line_cash_out_ftiq" model="account.payment.method.line">
            <field name="name">صرف نقدي ميداني</field>
        </record>

