            <field name="name">مشروع خطة محمد - الأسبوع 10</field>
        </record>
        <record id="demo_project_plan_rep2_week10" model="project.project">
            <field name="name">مشروع خطة علي - الأسبوع 10</field>
        </record>

        <record id="demo_plan_rep1_week10" model="ftiq.weekly.plan">
            <field name="name">الخطة الأسبوعية لمحمد - الأسبوع 10</field>
            <field name="team_id" ref="demo_team_sanaa"/>
            <field name="note">خطة معتمدة لزيارات الأطباء والمراكز ذات الأولوية العالية في صنعاء.</field>
        </record>
        <record id="demo_plan_rep2_week10" model="ftiq.weekly.plan">
            <field name="name">الخطة الأسبوعية لعلي - الأسبوع 10</field>
            <field name="team_id" ref="demo_team_sanaa"/>
            <field name="note">خطة مرفوعة للمراجعة وتتضمن متابعة التحصيل وفحص الأرفف في الصيدليات.</field>
        </record>

        <record id="demo_plan1_line_doctor1" model="ftiq.weekly.plan.line">
            <field name="user_id" ref="demo_user_rep1"/>
