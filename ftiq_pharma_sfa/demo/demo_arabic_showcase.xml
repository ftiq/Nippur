        <record id="demo_field_order_rep2_doctor5_line1" model="sale.order.line">
            <field name="name">طلبية دعم مخزون لمنتج جلوكوفاج 850 مجم</field>
        </record>

        <record id="demo_invoice_doctor1" model="account.move">
            <field name="ref">فاتورة تجريبية 001</field>
            <field name="ftiq_field_notes">فاتورة ناتجة عن طلبية ميدانية بعد زيارة معتمدة للدكتور عبدالله.</field>
        </record>
        <record id="demo_invoice_doctor5" model="account.move">
            <field name="ref">فاتورة تجريبية 002</field>
            <field name="ftiq_field_notes">فاتورة مرتبطة بمتابعة عيادة السكري والتحصيل الميداني.</field>
        </record>

        <record id="demo_payment_collection_rep1" model="account.payment">
            <field name="memo">تحصيل ميداني 001</field>
            <field name="ftiq_check_number">CHK-FTIQ-001</field>
            <field name="ftiq_check_date">2026-03-03</field>
            <field name="ftiq_bank_name">بنك اليمن والكويت</field>
        </record>
        <record id="demo_payment_collection_rep2" model="account.payment">
            <field name="memo">تحصيل ميداني 002</field>
            <field name="ftiq_check_number">CHK-FTIQ-002</field>
            <field name="ftiq_check_date">2026-03-04</field>
            <field name="ftiq_bank_name">بنك الكريمي</field>
        </record>

        <record id="demo_collection_line_rep1_inv1" model="ftiq.collection.line">
            <field name="payment_id" ref="demo_payment_collection_rep1"/>
            <field name="invoice_id" ref="demo_invoice_doctor1"/>
            <field name="allocated_amount">300.00</field>
        </record>
        <record id="demo_collection_line_rep2_inv2" model="ftiq.collection.line">
            <field name="payment_id" ref="demo_payment_collection_rep2"/>
            <field name="invoice_id" ref="demo_invoice_doctor5"/>
            <field name="allocated_amount">180.00</field>
        </record>

        <!-- الأهداف والمصروفات -->
        <record id="demo_target_rep1_visits" model="ftiq.sales.target">
            <field name="name">هدف زيارات محمد الشهري</field>
            <field name="notes">يركز على الأطباء ذوي الأولوية العالية في صنعاء وقياس الزيارات المعتمدة.</field>
        </record>
        <record id="demo_target_rep3_products" model="ftiq.sales.target">
