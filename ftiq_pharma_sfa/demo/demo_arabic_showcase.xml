            <field name="partner_id" ref="demo_doctor6"/>
            <field name="scheduled_date">2026-03-05</field>
            <field name="sequence">1</field>
            <field name="user_id" ref="demo_user_rep3"/>
            <field name="note">زيارة تمهيدية لتعريف الطبيب بالمنتجات المسكنة وخطة المتابعة القادمة.</field>
            <field name="state">pending</field>
        </record>

