        </record>
        <record id="demo_pharmacy2" model="res.partner">
            <field name="country_id" ref="base.ye"/>
            <field name="ftiq_client_category_id" ref="ftiq_client_category_pharmacy"/>
        </record>

        <record id="demo_doctor_baghdad_derma" model="res.partner">
            <field name="name">عيادة الدكتور رائد عبد الله / جلدية - الاسكان</field>
            <field name="is_ftiq_doctor" eval="True"/>
            <field name="ftiq_client_category_id" ref="ftiq_client_category_doctor"/>
            <field name="ftiq_specialty_id" ref="demo_specialty_dermatology"/>
            <field name="ftiq_classification_id" ref="demo_class_a"/>
            <field name="ftiq_prescriber_status_id" ref="demo_prescriber_active"/>
            <field name="ftiq_official_type_id" ref="demo_official_specialist"/>
            <field name="ftiq_workplace_type_id" ref="demo_workplace_clinic"/>
            <field name="ftiq_debt_classification_id" ref="demo_debt_none"/>
            <field name="ftiq_color_code_id" ref="demo_color_green"/>
