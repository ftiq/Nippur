        </record>

        <record id="demo_project_plan_rep3_week10" model="project.project">
            <field name="name">مشروع خطة عمر - الأسبوع 10</field>
            <field name="user_id" ref="demo_user_rep3"/>
            <field name="company_id" ref="base.main_company"/>
        </record>
        <record id="demo_plan_rep3_week10" model="ftiq.weekly.plan">
            <field name="name">الخطة الأسبوعية لعمر - الأسبوع 10</field>
            <field name="team_id" ref="demo_team_aden"/>
            <field name="task_type_id" ref="demo_task_followup"/>
            <field name="week_start">2026-03-02</field>
            <field name="state">draft</field>
            <field name="project_id" ref="demo_project_plan_rep3_week10"/>
            <field name="note">خطة قيد الإعداد لتوسيع التغطية في عدن وزيادة تفعيل الأطباء الجدد.</field>
        </record>
