<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ftiq_attendance_rule_rep" model="ir.rule">
        <field name="name">Attendance: Rep sees own</field>
        <field name="model_id" ref="model_ftiq_field_attendance"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_ftiq_rep'))]"/>
    </record>

    <record id="ftiq_attendance_rule_supervisor" model="ir.rule">
        <field name="name">Attendance: Supervisor sees team</field>
        <field name="model_id" ref="model_ftiq_field_attendance"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id.ftiq_supervisor_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_ftiq_supervisor'))]"/>
    </record>

    <record id="ftiq_attendance_rule_manager" model="ir.rule">
        <field name="name">Attendance: Manager sees all</field>
        <field name="model_id" ref="model_ftiq_field_attendance"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ftiq_manager'))]"/>
    </record>

