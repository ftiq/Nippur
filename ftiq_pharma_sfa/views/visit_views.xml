<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ftiq_visit_form" model="ir.ui.view">
        <field name="name">ftiq.visit.form</field>
        <field name="model">ftiq.visit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" type="object" string="Start Visit"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_end" type="object" string="End Visit"
                            class="btn-warning" invisible="state != 'in_progress'"/>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary" invisible="state not in ('draft', 'in_progress', 'returned')"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="btn-success" invisible="state != 'submitted'"
                            groups="ftiq_pharma_sfa.group_ftiq_supervisor"/>
                    <button name="action_return" type="object" string="Return"
                            class="btn-danger" invisible="state != 'submitted'"
                            groups="ftiq_pharma_sfa.group_ftiq_supervisor"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                            invisible="state != 'returned'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="sale_order_count" widget="statinfo" string="Orders"/>
                        </button>
                        <button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money">
                            <field name="payment_count" widget="statinfo" string="Collections"/>
                        </button>
                        <button name="action_view_stock_checks" type="object" class="oe_stat_button" icon="fa-cubes">
                            <field name="stock_check_count" widget="statinfo" string="Stock Checks"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="visit_date"/>
                            <field name="attendance_id"/>
                        </group>
                        <group>
                            <field name="plan_line_id"/>
                            <field name="is_planned"/>
                            <field name="unplanned_reason" invisible="is_planned"/>
                            <field name="outcome"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Details">
                            <field name="product_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="call_reason_id"/>
                                    <field name="outcome"/>
                                    <field name="samples_distributed"/>
                                    <field name="stock_on_hand"/>
                                    <field name="feedback"/>
                                    <field name="detail_notes" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Material View Log">
                            <field name="material_view_log_ids">
                                <list>
                                    <field name="material_id"/>
                                    <field name="product_id"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                    <field name="duration" string="Duration (min)"/>
                                </list>
                            </field>
                        </page>
                        <page string="GPS Data">
                            <group>
                                <group string="Start Location">
                                    <field name="start_time"/>
                                    <field name="start_latitude"/>
                                    <field name="start_longitude"/>
                                </group>
                                <group string="End Location">
                                    <field name="end_time"/>
                                    <field name="end_latitude"/>
                                    <field name="end_longitude"/>
                                </group>
                            </group>
                            <div>
                                <button name="action_show_on_map" type="object" string="Show on Map"
                                        class="btn-link" icon="fa-map-marker"/>
                            </div>
                        </page>
                        <page string="Feedback">
                            <field name="general_feedback" placeholder="General visit feedback..."/>
                        </page>
                        <page string="Actions" invisible="state not in ('in_progress', 'draft')">
                            <group>
                                <button name="action_create_sale_order" type="object" string="Create Field Order" class="btn-primary" icon="fa-shopping-cart"/>
                                <button name="action_create_payment" type="object" string="Create Cash Collection" class="btn-success" icon="fa-money"/>
                                <button name="action_create_stock_check" type="object" string="Create Stock Check" class="btn-info" icon="fa-cubes"/>
                            </group>
                        </page>
                        <page string="Photos &amp; Signature">
                            <group>
                                <group>
                                    <field name="photo_1" widget="image" options="{'size': [200, 200]}"/>
                                </group>
                                <group>
                                    <field name="photo_2" widget="image" options="{'size': [200, 200]}"/>
                                </group>
                                <group>
                                    <field name="photo_3" widget="image" options="{'size': [200, 200]}"/>
                                </group>
                                <group>
                                    <field name="signature" widget="signature"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="ftiq_visit_list" model="ir.ui.view">
        <field name="name">ftiq.visit.list</field>
        <field name="model">ftiq.visit</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'in_progress'"
                  decoration-success="state == 'approved'"
                  decoration-warning="state == 'returned'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="visit_date"/>
                <field name="partner_specialty_id" optional="show"/>
                <field name="partner_classification_id" optional="show"/>
                <field name="is_planned"/>
                <field name="outcome"/>
                <field name="duration" widget="float_time" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'in_progress'"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'returned'"
                       decoration-muted="state == 'draft'"
                       decoration-primary="state == 'submitted'"/>
            </list>
        </field>
    </record>

    <record id="ftiq_visit_kanban" model="ir.ui.view">
        <field name="name">ftiq.visit.kanban</field>
        <field name="model">ftiq.visit</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="visit_date"/>
                <field name="outcome"/>
                <field name="state"/>
                <field name="is_planned"/>
                <field name="duration"/>
                <field name="partner_specialty_id"/>
                <field name="activity_state"/>
                <progressbar field="activity_state" colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top mb-0">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'in_progress': 'info', 'submitted': 'primary', 'approved': 'success', 'returned': 'warning'}}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><strong><field name="partner_id"/></strong></div>
                                <div class="text-muted"><field name="partner_specialty_id"/></div>
                                <div>
                                    <i class="fa fa-user me-1"/><field name="user_id"/>
                                </div>
                                <div>
                                    <i class="fa fa-calendar me-1"/><field name="visit_date"/>
                                </div>
                                <div t-if="record.outcome.raw_value">
                                    <i class="fa fa-flag me-1"/><field name="outcome"/>
                                </div>
                                <div t-if="record.duration.raw_value">
                                    <i class="fa fa-clock-o me-1"/><field name="duration" widget="float_time"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="is_planned" widget="boolean"/>
                                    <field name="activity_ids" widget="kanban_activity"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="ftiq_visit_search" model="ir.ui.view">
        <field name="name">ftiq.visit.search</field>
        <field name="model">ftiq.visit</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <filter name="today" string="Today" domain="[('visit_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_week" string="This Week" domain="[('visit_date', '>=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <filter name="this_month" string="This Month" domain="[('visit_date', '>=', context_today().strftime('%Y-%m-01'))]"/>
                <separator/>
                <filter name="planned" string="Planned" domain="[('is_planned', '=', True)]"/>
                <filter name="unplanned" string="Unplanned" domain="[('is_planned', '=', False)]"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                <filter name="approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <filter name="returned" string="Returned" domain="[('state', '=', 'returned')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_user" string="Representative" context="{'group_by': 'user_id'}"/>
                    <filter name="group_partner" string="Client" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_specialty" string="Specialty" context="{'group_by': 'partner_specialty_id'}"/>
                    <filter name="group_classification" string="Classification" context="{'group_by': 'partner_classification_id'}"/>
                    <filter name="group_area" string="Area" context="{'group_by': 'partner_area_id'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'visit_date'}"/>
                    <filter name="group_outcome" string="Outcome" context="{'group_by': 'outcome'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="ftiq_visit_pivot" model="ir.ui.view">
        <field name="name">ftiq.visit.pivot</field>
        <field name="model">ftiq.visit</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="user_id" type="row"/>
                <field name="visit_date" type="col" interval="week"/>
                <field name="id" type="measure" string="Count"/>
            </pivot>
        </field>
    </record>

    <record id="ftiq_visit_graph" model="ir.ui.view">
        <field name="name">ftiq.visit.graph</field>
        <field name="model">ftiq.visit</field>
        <field name="arch" type="xml">
            <graph type="bar">
                <field name="user_id"/>
                <field name="id" type="measure" string="Count"/>
            </graph>
        </field>
    </record>

    <record id="action_ftiq_visit" model="ir.actions.act_window">
        <field name="name">Visits</field>
        <field name="res_model">ftiq.visit</field>
        <field name="view_mode">list,kanban,form,pivot,graph</field>
        <field name="search_view_id" ref="ftiq_visit_search"/>
    </record>

    <record id="action_ftiq_my_visits" model="ir.actions.act_window">
        <field name="name">My Visits</field>
        <field name="res_model">ftiq.visit</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'default_user_id': uid, 'search_default_today': 1}</field>
    </record>

    <record id="action_ftiq_visits_to_approve" model="ir.actions.act_window">
        <field name="name">Visits to Approve</field>
        <field name="res_model">ftiq.visit</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('state', '=', 'submitted')]</field>
    </record>

    <record id="ftiq_visit_product_line_list" model="ir.ui.view">
        <field name="name">ftiq.visit.product.line.list</field>
        <field name="model">ftiq.visit.product.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="visit_date"/>
                <field name="user_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="call_reason_id"/>
                <field name="outcome"/>
                <field name="samples_distributed" sum="Total Samples"/>
                <field name="stock_on_hand"/>
                <field name="feedback"/>
            </list>
        </field>
    </record>

    <record id="ftiq_visit_product_line_search" model="ir.ui.view">
        <field name="name">ftiq.visit.product.line.search</field>
        <field name="model">ftiq.visit.product.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_id"/>
                <field name="user_id"/>
                <field name="partner_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_product" string="Product" context="{'group_by': 'product_id'}"/>
                    <filter name="group_user" string="Representative" context="{'group_by': 'user_id'}"/>
                    <filter name="group_outcome" string="Outcome" context="{'group_by': 'outcome'}"/>
                    <filter name="group_reason" string="Call Reason" context="{'group_by': 'call_reason_id'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'visit_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="ftiq_visit_product_line_pivot" model="ir.ui.view">
        <field name="name">ftiq.visit.product.line.pivot</field>
        <field name="model">ftiq.visit.product.line</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="product_id" type="row"/>
                <field name="outcome" type="col"/>
                <field name="samples_distributed" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_ftiq_visit_product_line_report" model="ir.actions.act_window">
        <field name="name">Product Detail Report</field>
        <field name="res_model">ftiq.visit.product.line</field>
        <field name="view_mode">pivot,list,graph</field>
    </record>

    <record id="ftiq_material_view_log_list" model="ir.ui.view">
        <field name="name">ftiq.material.view.log.list</field>
        <field name="model">ftiq.material.view.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="visit_id"/>
                <field name="user_id"/>
                <field name="material_id"/>
                <field name="product_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="duration" string="Duration (min)" sum="Total"/>
            </list>
        </field>
    </record>

    <record id="ftiq_material_view_log_pivot" model="ir.ui.view">
        <field name="name">ftiq.material.view.log.pivot</field>
        <field name="model">ftiq.material.view.log</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="material_id" type="row"/>
                <field name="user_id" type="col"/>
                <field name="duration" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_ftiq_material_view_log_report" model="ir.actions.act_window">
        <field name="name">Material View Report</field>
        <field name="res_model">ftiq.material.view.log</field>
        <field name="view_mode">pivot,list</field>
    </record>

</odoo>
