<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ftiq_account_payment_form_inherit" model="ir.ui.view">
        <field name="name">account.payment.form.ftiq.inherit</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="is_field_collection" invisible="1"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <group string="Field Collection Details" invisible="not is_field_collection">
                    <group>
                        <field name="ftiq_collection_state" widget="badge" decoration-info="ftiq_collection_state == 'draft'" decoration-warning="ftiq_collection_state == 'collected'" decoration-success="ftiq_collection_state in ('deposited', 'verified')"/>
                        <field name="ftiq_visit_id"/>
                        <field name="ftiq_attendance_id"/>
                    </group>
                    <group>
                        <field name="ftiq_check_number" invisible="journal_id"/>
                        <field name="ftiq_check_date" invisible="journal_id"/>
                        <field name="ftiq_bank_name" invisible="journal_id"/>
                        <field name="ftiq_receipt_image" filename="ftiq_receipt_image_name"/>
                        <field name="ftiq_receipt_image_name" invisible="1"/>
                    </group>
                    <group string="GPS">
                        <field name="ftiq_latitude"/>
                        <field name="ftiq_longitude"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <record id="action_ftiq_field_collections" model="ir.actions.act_window">
        <field name="name">Cash Collections</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('is_field_collection', '=', True), ('payment_type', '=', 'inbound')]</field>
        <field name="context">{'default_is_field_collection': True, 'default_payment_type': 'inbound', 'default_partner_type': 'customer'}</field>
    </record>

    <record id="action_ftiq_my_collections" model="ir.actions.act_window">
        <field name="name">My Collections</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('is_field_collection', '=', True), ('payment_type', '=', 'inbound'), ('create_uid', '=', uid)]</field>
        <field name="context">{'default_is_field_collection': True, 'default_payment_type': 'inbound', 'default_partner_type': 'customer'}</field>
    </record>

</odoo>
