<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ftiq_stock_check_form" model="ir.ui.view">
        <field name="name">ftiq.stock.check.form</field>
        <field name="model">ftiq.stock.check</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_review" type="object" string="Mark Reviewed"
                            class="btn-success" invisible="state != 'submitted'"
                            groups="ftiq_pharma_sfa.group_ftiq_supervisor"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                            invisible="state != 'submitted'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,reviewed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="check_date"/>
                            <field name="visit_id"/>
                        </group>
                        <group>
                            <field name="total_items"/>
                            <field name="total_qty"/>
                            <field name="photo" widget="image" options="{'size': [200, 200]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Stock Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="stock_qty"/>
                                    <field name="batch_number" optional="show"/>
                                    <field name="expiry_date" optional="show"/>
                                    <field name="shelf_position" optional="hide"/>
                                    <field name="competitor_product" optional="show"/>
                                    <field name="competitor_qty" optional="show"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                        <page string="GPS">
                            <group>
                                <field name="latitude"/>
                                <field name="longitude"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="ftiq_stock_check_list" model="ir.ui.view">
        <field name="name">ftiq.stock.check.list</field>
        <field name="model">ftiq.stock.check</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'reviewed'"
                  decoration-info="state == 'submitted'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="check_date"/>
                <field name="total_items"/>
                <field name="total_qty" sum="Total"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'reviewed'"
                       decoration-info="state == 'submitted'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="ftiq_stock_check_kanban" model="ir.ui.view">
        <field name="name">ftiq.stock.check.kanban</field>
        <field name="model">ftiq.stock.check</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="check_date"/>
                <field name="total_items"/>
                <field name="total_qty"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top mb-0">
                                <strong><field name="name"/></strong>
                                <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'submitted': 'info', 'reviewed': 'success'}}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><strong><field name="partner_id"/></strong></div>
                                <div><i class="fa fa-user me-1"/><field name="user_id"/></div>
                                <div><i class="fa fa-calendar me-1"/><field name="check_date"/></div>
                                <div class="mt-1">
                                    <span class="badge text-bg-primary"><field name="total_items"/> items</span>
                                    <span class="badge text-bg-info"><field name="total_qty"/> qty</span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="ftiq_stock_check_search" model="ir.ui.view">
        <field name="name">ftiq.stock.check.search</field>
        <field name="model">ftiq.stock.check</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <filter name="today" string="Today" domain="[('check_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_user" string="Representative" context="{'group_by': 'user_id'}"/>
                    <filter name="group_partner" string="Client" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ftiq_stock_check" model="ir.actions.act_window">
        <field name="name">Stock Checks</field>
        <field name="res_model">ftiq.stock.check</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="ftiq_stock_check_search"/>
    </record>

    <record id="action_ftiq_my_stock_checks" model="ir.actions.act_window">
        <field name="name">My Stock Checks</field>
        <field name="res_model">ftiq.stock.check</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'default_user_id': uid}</field>
    </record>

</odoo>
