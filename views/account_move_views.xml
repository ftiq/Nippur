<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ftiq_account_move_form_inherit" model="ir.ui.view">
        <field name="name">account.move.form.ftiq.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="is_field_invoice" invisible="1"/>
                <field name="ftiq_visit_id" optional="hide"/>
                <field name="ftiq_attendance_id" optional="hide"/>
                <field name="ftiq_daily_task_id" optional="hide"/>
                <field name="ftiq_user_id" optional="hide"/>
                <field name="ftiq_field_notes" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="action_ftiq_client_invoices" model="ir.actions.act_window">
        <field name="name">Client Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('move_type', '=', 'out_invoice')]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
    </record>

</odoo>
