<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ftiq_client_category_list" model="ir.ui.view">
        <field name="name">ftiq.client.category.list</field>
        <field name="model">ftiq.client.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>
    <record id="action_ftiq_client_category" model="ir.actions.act_window">
        <field name="name">Client Categories</field>
        <field name="res_model">ftiq.client.category</field>
        <field name="view_mode">list</field>
    </record>

    <record id="ftiq_specialty_list" model="ir.ui.view">
        <field name="name">ftiq.specialty.list</field>
        <field name="model">ftiq.specialty</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>
    <record id="ftiq_specialty_form" model="ir.ui.view">
        <field name="name">ftiq.specialty.form</field>
        <field name="model">ftiq.specialty</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Subspecialties">
                            <field name="subspecialty_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="active" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_ftiq_specialty" model="ir.actions.act_window">
        <field name="name">Specialties</field>
        <field name="res_model">ftiq.specialty</field>
        <field name="view_mode">list,form</field>
    </record>

