    <record id="ftiq_task_type_list" model="ir.ui.view">
        <field name="name">ftiq.task.type.list</field>
        <field name="model">ftiq.task.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>
    <record id="action_ftiq_task_type" model="ir.actions.act_window">
        <field name="name">Task Types</field>
        <field name="res_model">ftiq.task.type</field>
        <field name="view_mode">list</field>
    </record>

    <record id="ftiq_task_profile_list" model="ir.ui.view">
        <field name="name">ftiq.task.profile.list</field>
        <field name="model">ftiq.task.profile</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="requires_check_in"/>
                <field name="requires_confirmation"/>
                <field name="requires_photos"/>
                <field name="allow_manual_completion"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="ftiq_task_profile_form" model="ir.ui.view">
        <field name="name">ftiq.task.profile.form</field>
        <field name="model">ftiq.task.profile</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="requires_partner"/>
                            <field name="requires_associated_partner"/>
                            <field name="requires_user"/>
                            <field name="allow_manual_completion"/>
                        </group>
                    </group>
                    <group string="Execution Rules">
                        <group>
                            <field name="requires_check_in"/>
                            <field name="requires_products"/>
                            <field name="requires_confirmation"/>
                        </group>
                        <group>
                            <field name="requires_photos"/>
                            <field name="required_photo_count" invisible="not requires_photos"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" placeholder="Explain how this profile should execute in the field..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ftiq_task_profile" model="ir.actions.act_window">
        <field name="name">Task Profiles</field>
        <field name="res_model">ftiq.task.profile</field>
        <field name="view_mode">list,form</field>
    </record>

