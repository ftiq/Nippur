<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ftiq_account_payment_form_inherit" model="ir.ui.view">
        <field name="name">account.payment.form.ftiq.inherit</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="is_field_collection" invisible="1"/>
                <field name="ftiq_user_id" invisible="not is_field_collection"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_ftiq_collect" type="object" string="Mark Collected"
                        class="btn-info"
                        invisible="not is_field_collection or ftiq_collection_state != 'draft'"/>
                <button name="action_ftiq_deposit" type="object" string="Mark Deposited"
                        class="btn-warning"
                        invisible="not is_field_collection or ftiq_collection_state != 'collected'"/>
                <button name="action_ftiq_verify" type="object" string="Verify"
                        class="btn-success"
                        invisible="not is_field_collection or ftiq_collection_state != 'deposited'"
                        groups="ftiq_pharma_sfa.group_ftiq_supervisor"/>
                <button name="action_ftiq_reload_invoices" type="object" string="Load Open Invoices"
                        class="btn-secondary"
                        invisible="not is_field_collection or not partner_id or state not in ('draft', 'in_process', 'paid')"/>
                <button name="action_ftiq_distribute_amount" type="object" string="Distribute Amount"
                        class="btn-secondary"
                        invisible="not is_field_collection or not ftiq_collection_line_ids"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <group string="Field Collection Details" invisible="not is_field_collection">
                    <group>
                        <field name="ftiq_collection_state" widget="badge"
                               decoration-info="ftiq_collection_state == 'draft'"
                               decoration-warning="ftiq_collection_state in ('collected', 'deposited')"
                               decoration-success="ftiq_collection_state == 'verified'"/>
                        <field name="ftiq_team_id" readonly="1"/>
                        <field name="ftiq_visit_id"/>
                        <field name="ftiq_attendance_id"/>
                        <field name="ftiq_daily_task_id"/>
                    </group>
                    <group>
                        <field name="ftiq_allocated_amount" readonly="1"/>
                        <field name="ftiq_unallocated_amount" readonly="1"/>
                        <field name="ftiq_open_invoice_count" readonly="1"/>
                        <field name="invoice_ids" widget="many2many_tags" readonly="1"/>
                    </group>
                    <group>
                        <field name="ftiq_check_number"/>
                        <field name="ftiq_check_date"/>
                        <field name="ftiq_bank_name"/>
                        <field name="ftiq_receipt_image" filename="ftiq_receipt_image_name"/>
                        <field name="ftiq_receipt_image_name" invisible="1"/>
                    </group>
                    <group string="GPS">
                        <field name="ftiq_latitude"/>
                        <field name="ftiq_longitude"/>
                    </group>
                    <separator string="Invoice Allocation"/>
                    <field name="ftiq_collection_line_ids" nolabel="1" context="{'default_payment_id': id}">
                        <list editable="bottom">
                            <field name="invoice_id"
                                   domain="[('move_type', '=', 'out_invoice'), ('state', '=', 'posted'), ('partner_id', 'child_of', parent.partner_id), ('amount_residual', '&gt;', 0)]"/>
                            <field name="invoice_date" optional="show"/>
                            <field name="due_date" optional="show"/>
                            <field name="invoice_residual_payment" string="Residual"/>
                            <field name="allocated_amount"/>
                            <field name="reconciled_amount" readonly="1" optional="show"/>
                            <field name="remaining_amount" readonly="1" optional="show"/>
                            <field name="invoice_payment_state" widget="badge"/>
                        </list>
                    </field>
                </group>
            </xpath>
        </field>
    </record>

    <record id="action_ftiq_field_collections" model="ir.actions.act_window">
        <field name="name">Cash Collections</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('is_field_collection', '=', True), ('payment_type', '=', 'inbound')]</field>
        <field name="context">{'default_is_field_collection': True, 'default_payment_type': 'inbound', 'default_partner_type': 'customer', 'default_ftiq_user_id': uid}</field>
    </record>

    <record id="action_ftiq_my_collections" model="ir.actions.act_window">
        <field name="name">My Collections</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('is_field_collection', '=', True), ('payment_type', '=', 'inbound'), ('ftiq_user_id', '=', uid)]</field>
        <field name="context">{'default_is_field_collection': True, 'default_payment_type': 'inbound', 'default_partner_type': 'customer', 'default_ftiq_user_id': uid}</field>
    </record>

</odoo>
