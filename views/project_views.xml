<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ftiq_project_task_form_inherit" model="ir.ui.view">
        <field name="name">project.task.form.ftiq.inherit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_id']" position="after">
                <field name="ftiq_plan_id" optional="hide"/>
                <field name="ftiq_plan_line_id" optional="hide"/>
                <field name="ftiq_daily_task_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="ftiq_project_task_list_inherit" model="ir.ui.view">
        <field name="name">project.task.list.ftiq.inherit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_id']" position="after">
                <field name="ftiq_plan_id" optional="hide"/>
                <field name="ftiq_daily_task_id" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>
