<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form view for Telegram Bot -->
        <record id="view_telegram_bot_form" model="ir.ui.view">
            <field name="name">telegram.bot.form</field>
            <field name="model">telegram.bot</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="token" password="True"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="webhook_url" readonly="1"/>
                                <button name="set_webhook" string="Set Webhook" type="object" class="btn-primary"/>
                            </group>
                        </group>
                        <field name="chat_ids">
                            <tree>
                                <field name="chat_id"/>
                                <field name="username"/>
                                <field name="first_name"/>
                                <field name="last_name"/>
                                <field name="active"/>
                            </tree>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree view for Telegram Bot -->
        <record id="view_telegram_bot_tree" model="ir.ui.view">
            <field name="name">telegram.bot.tree</field>
            <field name="model">telegram.bot</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <!-- Action for Telegram Bot -->
        <record id="action_telegram_bot" model="ir.actions.act_window">
            <field name="name">Telegram Bots</field>
            <field name="res_model">telegram.bot</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- Menu item -->
        <menuitem id="menu_telegram_bot" name="Telegram Bot" 
                 parent="base.menu_administration" action="action_telegram_bot"/>
    </data>
</odoo>