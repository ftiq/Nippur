<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form view for Telegram Bot -->
        <record id="view_telegram_bot_form" model="ir.ui.view">
            <field name="name">telegram.bot.form</field>
            <field name="model">telegram.bot</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="token" password="True"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="webhook_url" readonly="1"/>
                                <button name="set_webhook" string="Set Webhook" type="object" class="btn-primary"/>
                            </group>
                        </group>
                        <field name="chat_ids" widget="many2many_tags"/>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree view for Telegram Bot -->
        <record id="view_telegram_bot_tree" model="ir.ui.view">
            <field name="name">telegram.bot.tree</field>
            <field name="model">telegram.bot</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <!-- Action for Telegram Bot -->
        <record id="action_telegram_bot" model="ir.actions.act_window">
            <field name="name">Telegram Bots</field>
            <field name="res_model">telegram.bot</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- Action for Telegram Chat -->
        <record id="action_telegram_chat" model="ir.actions.act_window">
            <field name="name">Telegram Chats</field>
            <field name="res_model">telegram.chat</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- Tree view for Telegram Chat -->
        <record id="view_telegram_chat_tree" model="ir.ui.view">
            <field name="name">telegram.chat.tree</field>
            <field name="model">telegram.chat</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="chat_id"/>
                    <field name="username"/>
                    <field name="first_name"/>
                    <field name="last_name"/>
                    <field name="bot_id"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <!-- Form view for Telegram Chat -->
        <record id="view_telegram_chat_form" model="ir.ui.view">
            <field name="name">telegram.chat.form</field>
            <field name="model">telegram.chat</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="chat_id"/>
                                <field name="username"/>
                                <field name="first_name"/>
                                <field name="last_name"/>
                            </group>
                            <group>
                                <field name="bot_id"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>