<odoo>
    <record id="view_order_form_inherit_representative" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.representative</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group>
                    <field name="representative_id" string="Representative"/>
                </group>
                <notebook>
                    <page string="Gifts">
                        <field name="order_line">
                            <tree editable="bottom">
                                <field name="product_id" string="Product"/>
                                <field name="product_uom_qty" string="Quantity"/>
                                <field name="gift_quantity" string="Gift Quantity"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
