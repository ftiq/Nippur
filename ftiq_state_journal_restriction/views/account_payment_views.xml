<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_payment_form_ftiq_state_journal" model="ir.ui.view">
        <field name="name">account.payment.form.ftiq.state.journal</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <field name="journal_id" position="before">
                <field name="ftiq_allowed_journal_ids" invisible="1"/>
            </field>
            <field name="journal_id" position="attributes">
                <attribute name="domain">[('id', 'in', ftiq_allowed_journal_ids)]</attribute>
            </field>
        </field>
    </record>
</odoo>
