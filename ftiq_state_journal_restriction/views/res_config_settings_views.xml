<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ftiq_res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.account.ftiq.state.journals</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="account.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='account']/block[@id='pay_invoice_online_setting_container']" position="inside">
                    <setting string="Restrict Journals by Partner State" company_dependent="1">
                        <field name="ftiq_use_state_journal_restriction"/>
                    </setting>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
