<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ftiq_view_country_state_form" model="ir.ui.view">
            <field name="name">res.country.state.form.ftiq.journals</field>
            <field name="model">res.country.state</field>
            <field name="inherit_id" ref="base.view_country_state_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet/group" position="inside">
                    <field name="ftiq_journal_ids" widget="many2many_tags" options="{'no_create': True}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
